<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.DashboardController">

    <left>
        <VBox spacing="10" prefWidth="200" styleClass="sidebar">

            <Label text="NexusForge" styleClass="sidebar-title"/>

            <Button text="Dashboard"
                    fx:id="dashboardBtn"
                    onAction="#showDashboard"
                    maxWidth="Infinity"/>

            <Button text="Employees"
                    fx:id="employeeBtn"
                    onAction="#showEmployees"
                    maxWidth="Infinity"/>

            <Button text="Attendance"
                    fx:id="attendanceBtn"
                    onAction="#showAttendance"
                    maxWidth="Infinity"/>

            <Button text="Reports"
                    fx:id="reportBtn"
                    onAction="#showReports"
                    maxWidth="Infinity"/>

            <Button text="Logout"
                    fx:id="logoutBtn"
                    onAction="#logout"
                    maxWidth="Infinity"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>